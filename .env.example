# Kopieren nach .env und Werte anpassen. .env wird nicht eingecheckt (siehe .gitignore).

DB_NAME=tododb
DB_USER=todo
DB_PASSWORD=change-me

# Mind. 32 Zeichen für HS256
JWT_SECRET=change-me-change-me-change-me-change-me

# Kommagetrennte Liste der Origins, die auf die API zugreifen dürfen
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
